<% layout("layouts/boilerplate.ejs"); %>

<body>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <h2 class="mb-4 text-center">Create New Listing</h2>

                <form action="/listings/new" method="POST" novalidate class="needs-validation">

                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input
                            type="text"
                            name="listing[title]"
                            class="form-control"
                            placeholder="Enter Your Title"
                            required
                        >
                        <div class="invalid-feedback">Please write Title again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea
                            name="listing[description]"
                            class="form-control"
                            rows="4"
                            placeholder="Enter Your Description"
                            required
                        ></textarea>
                        <div class="invalid-feedback">Please write Description again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input
                            type="text"
                            name="listing[image][url]"
                            class="form-control"
                            placeholder="Enter Your URL"
                        >
                        <div class="invalid-feedback">Please write Image again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Price</label>
                        <input
                            type="text"
                            name="listing[price]"
                            class="form-control"
                            placeholder="Enter Your Price"
                            required
                        >
                        <div class="invalid-feedback">Please write Price again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input
                            type="text"
                            name="listing[location]"
                            class="form-control"
                            placeholder="Enter Your Location"
                            required
                        >
                        <div class="invalid-feedback">Please write Location again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <input
                            type="text"
                            name="listing[country]"
                            class="form-control"
                            placeholder="Enter Your Country"
                            required
                        >
                        <div class="invalid-feedback">Please Check Country again!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <button type="submit" class="btn btn-dark">
                        Submit
                    </button>

                </form>

            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit!</title>
</head>
<body>
    <h2>ENter the New Details Here -></h2>    <br>
<form action="/listings/<%=user._id%>/edit?_method=PUT" method="post">
    
    <input type="text" name="edit[name]" value="<%=user.title%>"   placeholder="Enter Your New Title ...">
    <br>    <br>

<textarea  name="edit[description]" placeholder="Enter Your New Description ..."></textarea>
    <br>      <br>  
<input type="number" value="<%=user.price%>"  name="edit[price]" placeholder="Enter Your New Price ...">
    <br>
            <br>
<input type="text" value="<%=user.location%>"  name="edit[location]" placeholder="Enter Your New Location ...">
        <br>
    <br>

        <input type="text"  value="<%=user.country%>" name="edit[country]" placeholder="Enter Your New Country ...">
            <br>
    <br>

            <button type="submit">Submit</button>

</form>
    
</body>
</html>
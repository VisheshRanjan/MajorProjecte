<% layout("/layouts/boilerplate"); %>
<div class="row mt-3">
<div class="col-8">

<body>
    <h2>Edit Your Listing -></h2>    <br>
<form action="/listings/<%=user._id%>/edit?_method=PUT" method="post" novalidate class="needs-validation">
    
    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input
                            type="text"
                            name="listing[title]"
                            class="form-control"
                            placeholder="Enter Your Title"
                            value="<%=user.title%>"
                            required
                        >
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>

<div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea
                            type="text"
                            name="listing[description]"
                            class="form-control"
                            placeholder="Enter Your Title"
                                    required> 
                                    <%=user.description%></textarea>
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>
<div class="mb-3">
                        <label class="form-label">URL</label>
                        <input
                            type="text"
                            name="listing[image][url]"
                            class="form-control"
                            placeholder="Enter Your URL"
                            required
                                                        value="<%=user.image.url%>"

                        >
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>

                    <div class="card mb-3">
  <img src="<%= user.image.url%>" class="card-img-top" alt="image">

</div>
                    <div class="row">

<div class="mb-3 col-md-4">
                        <label class="form-label">Price</label>
                        <input
                            type="text"
                            name="listing[price]"
                            class="form-control"
                            placeholder="Enter Your Price"
                            required
                                                        value="<%=user.price%>"

                        >
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>
<div class="mb-3 col-md-8">
                        <label class="form-label">Location</label>
                        <input
                            type="text"
                            name="listing[location]"
                            class="form-control"
                            placeholder="Enter Your Location"
                            required
                                                        value="<%=user.location%>"

                        >
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>
                    </div>

        <div class="mb-3">
                        <label class="form-label">Country</label>
                        <input
                            type="text"
                            name="listing[country]"
                            class="form-control"
                            placeholder="Enter Your Country"
                            required
                                                        value="<%=user.country%>"

                        >
                        <div class="invalid-feedback">Please Complete these!</div>
                        <div class="valid-feedback"></div>
                    </div>

            <button type="submit" class="btn btn-dark edit-btn">Submit</button>

</form>
    
</body>
</div>

</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Here Is the Info</title>
</head>
<body>
    <h2><%= allList?.title %></h2>

    <% if (allList?.image?.url) { %>
        <img src="<%= allList.image.url %>" width="400">
    <% } %>

    <p><%= allList?.location %></p>
    <p><%= allList?.country %></p>

    <form method="post" action="/listings/<%=allList._id%>/delete">
        <button>Delete</button>
    </form>
</body>
</html>